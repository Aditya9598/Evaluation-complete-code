# Scorer gateway (local A3)
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8003
ENVIRONMENT=development
DEBUG=true

# Live scraper API (dashboard + worker fetch)
SCRAPER_API_BASE_URL=https://new-scrapper-provider-dev.internal.production.gm.paytmmoney.com
SCRAPER_API_KEY=

# Worker
GATEWAY_BASE_URL=http://127.0.0.1:8003
SCORER_BIN=../scorer/target/debug/scorer
WORKER_POLL_INTERVAL_MS=2000
WORKER_SCORER_TIMEOUT_MS=5000
WORKER_NEWS_QUERY=tata motors
WORKER_NEWS_LIMIT=3
