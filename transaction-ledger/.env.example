# Copy this file to .env and update values for your environment
# cp .env.example .env

# Server
APP_HOST=127.0.0.1
APP_PORT=8000
ENVIRONMENT=development
DEBUG=true

# Credentials (change before production)
SECRET_KEY=your-secret-key-here
API_KEY=your-api-key-here

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DATABASE_URL=postgresql://postgres:your-db-password-here@localhost:5432/postgres
